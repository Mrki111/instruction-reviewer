{
  "rules": [
    {
      "id": "INSTRUCTIONS_COMPLIANCE_001",
      "enabled": true,
      "severity": "medium",
      "description": "LLM-based check: ask Claude whether the diff or commit messages violate any rule from AGENTS.md / CLAUDE.md.",
      "model": "claude-sonnet-4-6",
      "max_tokens": 4096,
      "max_diff_chars": 200000,
      "timeout_seconds": 120,
      "max_retries": 2,
      "fail_open": true,
      "fail_open_severity": "low"
    }
  ]
}
